<!-- Version 1.11 Authorized for public release -->
<xs:schema elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:include schemaLocation="include_v1.11.xsd"/>
    <xs:element name="Root">
        <xs:complexType>
            <xs:sequence>
                <xs:element minOccurs="1" maxOccurs="512" name="WOK_Player_Profile_v1.11">
                    <xs:complexType>
                        <xs:sequence>
                            <!-- general -->
                            <xs:element maxOccurs="1" minOccurs="1" name="Record_ID" type="UID"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Extraction_Date" type="dateTimeUTC"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Operator_ID" type="stringMedium"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Data_Safe_ID" type="stringMedium"/>
							<!-- if this is a replacement record: in Replaced_Record_ID, fill in the ID of the record it replaces -->
							<xs:element maxOccurs="1" minOccurs="0" name="Replaced_Record_ID" type="UID"/>
                            <!-- specific -->
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_ID" type="stringMedium"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_Registration_Datetime" type="dateTimeUTC"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_DOB" type="xs:date"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_Modified" type="dateTimeUTC"/>
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_Status">
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="ACTIVE"/>
                                        <xs:enumeration value="TRIAL"/>
                                        <xs:enumeration value="SUSPENDED"/>
                                        <xs:enumeration value="SUSPENDED_DEATH"/>
                                        <xs:enumeration value="BLOCKED"/>
                                        <xs:enumeration value="SELF_EXCLUDED_TEMP"/>
                                        <xs:enumeration value="SELF_EXCLUDED_INDEF"/>
                                        <xs:enumeration value="OTHER"/>
                                        <!-- More values may be added in future versions. -->
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_EOD_Balance" type="monetaryAmount"/>
                            <xs:element maxOccurs="unbounded" minOccurs="0" name="Player_Profile_Bank_Account">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Bank_Account_ID" type="stringMedium"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Bank_Account_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Bank_Account_Active" type="xs:boolean"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
</xs:schema>


