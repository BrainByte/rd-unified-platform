							<xs:element maxOccurs="1" minOccurs="0" name="Replaced_Record_ID" type="UID"/>
                            <!-- specific -->
                            <xs:element maxOccurs="1" minOccurs="1" name="Player_Profile_ID" type="stringMedium"/>
                            <xs:element name="Limit_Deposit" maxOccurs="unbounded" minOccurs="1">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Deposit_Request_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Deposit_Start_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Deposit_Amount" type="xs:int"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Deposit_Time_Window" type="timeWindow"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="Limit_Participation" maxOccurs="unbounded" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Participation_Request_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Participation_Start_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Participation_Amount" type="xs:int"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Participation_Time_Window" type="timeWindow"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="Limit_Login" maxOccurs="unbounded" minOccurs="1">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Login_Request_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Login_Start_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Login_Duration" type="xs:float"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Login_Time_Window" type="timeWindow"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="Limit_Game_Type" maxOccurs="unbounded" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Game_Type_Request_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="0" name="Game_Type_Start_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="0" name="Game_Type_End_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Game_Type_Type" type="stringMedium"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Game_Type_Time_Window" type="timeWindow"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="Limit_Balance" maxOccurs="unbounded" minOccurs="1">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Balance_Request_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Balance_Start_Datetime" type="dateTimeUTC"/>
                                        <xs:element maxOccurs="1" minOccurs="1" name="Balance_Amount" type="xs:int"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
