<?xml version="1.0" encoding="UTF-8"?>
      
      <xs:schema xmlns:fase2.1="http://skat.dk/begrebsmodel/2009/01/15/"
                 xmlns:xs="http://www.w3.org/2001/XMLSchema"
                 targetNamespace="http://skat.dk/begrebsmodel/2009/01/15/"
                 elementFormDefault="qualified"
                 version="1.0">
            
            <xs:simpleType name="BeløbPositivNegativ10Decimaler10Type">
               <xs:annotation>
                  <xs:documentation>Et positivt eller negativt beløb med længden 10 samt 10 decimaler. Værdierne ligger indenfor følgende område: -9.999.999.999 til 9.999.999.999</xs:documentation>
               </xs:annotation>
               <xs:restriction base="xs:decimal">
                  <xs:maxInclusive value="9999999999"/>
                  <xs:minInclusive value="-9999999999"/>
                  <xs:totalDigits value="20"/>
                  <xs:fractionDigits value="10"/>
               </xs:restriction>
            </xs:simpleType>
         </xs:schema>
