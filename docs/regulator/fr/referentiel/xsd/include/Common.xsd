  <xs:element name="BonusAvant" type="bonus"/>
  <xs:element name="BonusMouvement" type="mouvement"/>
  <xs:element name="BonusNom" type="xs:string"/>
  <xs:element name="Clair" type="string-256"/>
  <xs:element name="DateEvt" type="date-aammjjhhmmss"/>
  <xs:element name="DateHeure" type="date-aammjjhhmmss"/>
  <xs:element name="DateMise" type="date-aammjjhhmmss"/>
  <xs:element name="GainAbond" type="mouvement"/>
  <xs:element name="Gain" type="mouvement"/>
  <xs:element name="HashJoueur" type="sha1"/>
  <xs:element name="IDCoffre" type="xs:nonNegativeInteger"/>
  <xs:element name="IDEvt" type="xs:nonNegativeInteger"/>
  <xs:element name="IDJoueur" type="string-64"/>
  <xs:element name="IDMonnaie" type="string-64"/>
  <xs:element name="IDOper" type="operator"/>
  <xs:element name="IDSession" type="string-256"/>
  <xs:element name="IDRef" type="string-256"/>
  <xs:element name="Info" type="xs:string"/>
  <xs:element name="NombreChoix" type="xs:integer"/>
  <xs:element name="IPJoueur" type="IP"/>
  <xs:element name="Login" type="string-64"/>
  <xs:element name="MiseAbond" type="mouvement"/>
  <xs:element name="MontAbond" type="mouvement"/>
  <xs:element name="MontantRembours" type="mouvement"/>
  <xs:element name="Mouvement" type="mouvement"/>
  <xs:element name="Nom" type="xs:string"/>
  <xs:element name="Nom2" type="string-64"/>
  <xs:element name="Nom256" type="string-256"/>
  <xs:element name="Pseudo" type="string-64"/>
  <xs:element name="IDTirage" type="string-64"/>
  <xs:element name="IDGroupe" type="string-64"/>
  <xs:element name="SoldeApres" type="solde"/>
  <xs:element name="SoldeApresGain" type="solde"/>
  <xs:element name="SoldeApresRembours" type="solde"/>
  <xs:element name="SoldeAvantGain" type="solde"/>
  <xs:element name="SoldeAvantRembours" type="solde"/>
  <xs:element name="SoldeAvant" type="solde"/>
  <xs:element name="MonnaieAvant" type="solde"/>
  <xs:element name="MonnaieApres" type="solde"/>
  <xs:element name="MontantMonnaie" type="mouvement"/>
  <xs:element name="Unite" type="xs:string"/>
  <xs:element name="SoldeMouvement" type="mouvement"/>
  <xs:element name="MontantAchat" type="mouvement"/>
  <xs:element name="Tech" type="string-256"/>
  <xs:element name="TechJeu" type="xs:string"/>
  <xs:element name="Option" type="xs:string"/>
  <xs:element name="Supervision" type="empty"/>
  <xs:element name="Jackpot" type="empty"/>
  <xs:element name="Mutuel" type="empty"/>
  <xs:element name="Test" type="empty"/>
  <xs:element name="Tel" type="empty"/>
  <xs:element name="Retransmission" type="empty"/>
  <xs:element name="Hippodrome" type="xs:string"/>
  <xs:element name="Pays" type="string-64"/>
  <xs:element name="Reunion" type="xs:integer"/>
  <xs:element name="Nombre" type="xs:integer"/>
  <xs:element name="CNom" type="xs:string"/>
  <xs:element name="CNum" type="xs:integer"/>
  <xs:element name="Description" type="xs:string"/>
  <xs:element name="Classement" type="xs:integer"/>
  <xs:element name="IDPointDeVente" type="string-64"/>
  <xs:element name="Ad" type="string-256"/>
  <xs:element name="CP" type="postal"/>
  <xs:element name="Ville" type="string-64"/>
  <xs:element name="Taille" type="nonNegativeDecimal"/>
  <xs:element name="Taille2" type="string-64"/>
  <xs:element name="Valeur" type="nonNegativeDecimal"/>
  <xs:element name="Oper" type="xs:string"/>
</xs:schema>
