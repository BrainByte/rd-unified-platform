<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:types="https://det.tech.arjel/2.0.0-draft/common/types" version="2.0.0-draft" elementFormDefault="unqualified" targetNamespace="https://det.tech.arjel/2.0.0-draft/common/types">
  <xs:simpleType name="IPv4">
    <xs:restriction base="xs:string">
      <xs:pattern value="([01]?\d\d?|2[0-4]\d|25[0-5])\.([01]?\d\d?|2[0-4]\d|25[0-5])\.([01]?\d\d?|2[0-4]\d|25[0-5])\.([01]?\d\d?|2[0-4]\d|25[0-5])"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="publicIPv4">
    <xs:restriction base="types:IPv4">
      <xs:pattern value="[^102].*|0([^.].*)?|12([^7].*)?|20([^3].*)?|17([^2].*)?|16([^9].*)?|19([^82].*)?|169([^.].*)?|225([^.].*)?|228([^.].*)?|203([^.].*)?|172([^.].*)?|192([^.].*)?|224([^.].*)?|227([^.].*)?|25.([^.].*)?|10([^0.].*)?|226([^.].*)?|198([^.].*)?|229([^.].*)?|23.([^.].*)?|100([^.].*)?|24.([^.].*)?|169\.([^2].*)?|203\.([^0].*)?|2([^03254].*)?|1([^90276].*)?|22([.0123].*)?|169\.2([^5].*)?|192\.1([^6].*)?|192\.8([^8].*)?|198\.5([^1].*)?|198\.([^15].*)?|203\.0([^.].*)?|192\.0([^.].*)?|198\.1([^98].*)?|198\.51([^.].*)?|172\.18([^.].*)?|172\.19([^.].*)?|172\.2.([^.].*)?|198\.19([^.].*)?|192\.16([^8].*)?|198\.18([^.].*)?|100\.9.([^.].*)?|172\.16([^.].*)?|169\.25([^4].*)?|192\.([^108].*)?|192\.88([^.].*)?|172\.([^132].*)?|172\.3([^10].*)?|172\.17([^.].*)?|100\.8.([^.].*)?|100\.7.([^.].*)?|100\.11.([^.].*)?|100\.1([^102].*)?|203\.0\.([^1].*)?|100\.10.([^.].*)?|100\.12([.89].*)?|192\.0\.2([^.].*)?|100\.6([.0123].*)?|198\.51\.([^1].*)?|100\.([^98176].*)?|192\.88\.([^9].*)?|172\.1([^9876].*)?|192\.0\.0([^.].*)?|203\.0\.1([^1].*)?|192\.0\.([^02].*)?|192\.88\.9([^9].*)?|198\.51\.1([^0].*)?|203\.0\.11([^3].*)?|198\.51\.10([^0].*)?|192\.88\.99([^.].*)?"/>
