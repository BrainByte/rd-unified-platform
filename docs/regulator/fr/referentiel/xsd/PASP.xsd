        <xs:element maxOccurs="1" minOccurs="0" ref="SoldeAvantGain"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="Gain"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="SoldeApresGain"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="GainAbond"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="Info"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="BonusAvantGain"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="BonusMouvement"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="BonusApresGain"/>
        <xs:element maxOccurs="1" minOccurs="0" ref="Unite"/>        
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
